# === ECR ===
ECR_REGISTRY=123456789012.dkr.ecr.ap-southeast-1.amazonaws.com
IMAGE_TAG=latest

# === Database (Supabase) ===
DATABASE_URL=postgresql+asyncpg://your-user:your-password@your-host:5432/postgres

# === AWS (for HLS S3 uploads) ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
S3_BUCKET_NAME=

# === HLS ===
HLS_API_KEY=
WEBHOOK_URL=
WEBHOOK_SECRET=

# === FUTURE: Uncomment when deploying performa-edu ===
# JWT_SECRET=change-me-minimum-32-characters-long-secret-key
# JWT_EXPIRES_IN=7d
# JWT_REFRESH_EXPIRES_IN=30d
